{
  "manifest_version": 3,
  "name": "NEAR Contract Verifier",
  "version": "1.0.0",
  "description": "Verify whether a NEAR account has deployed contract code and inspect its on-chain hash.",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "host_permissions": [
    "https://rpc.mainnet.near.org/*",
    "https://rpc.testnet.near.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Verify NEAR contract"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "near-contract-verifier@example.com",
      "strict_min_version": "109.0"
    }
  }
}
